name: CI

on: [push, pull_request]

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.10"
      # Prophet is heavy and not needed for the fast tests; install the rest.
      - run: pip install pandas numpy openpyxl matplotlib seaborn ruff pytest
      - run: ruff check .
      # The forecast smoke test self-skips when prophet is absent.
      - run: pytest -q
